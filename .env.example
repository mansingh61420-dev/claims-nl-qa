# Copy to .env and fill in. Never commit .env.

# OpenAI API key (required for NL→SQL and answer phrasing)
OPENAI_API_KEY=

# Model id (optional; default is set in application settings)
OPENAI_MODEL=gpt-4o-mini

# Path to synthetic_claims.csv (optional; default resolves to docs/synthetic_claims.csv)
# DATA_PATH=
